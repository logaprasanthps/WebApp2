{
  "version": 2,
  "builds": [
    {
      "src": "Dockerfile",
      "use": "@vercel/dockerfile",
      "config": { "maxLambdaSize": "3008mb" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "ASPNETCORE_ENVIRONMENT": "Production",
    "ASPNETCORE_URLS": "http://+:8080"
  }
}
